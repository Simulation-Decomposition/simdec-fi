---
const { title = "SimDec" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      :root { color-scheme: light; }
      body { margin: 0; font-family: system-ui, sans-serif; line-height: 1.5; }
      a { color: inherit; }
      .wrap { max-width: 1000px; margin: 0 auto; padding: 0 1rem; }
      header { border-bottom: 1px solid rgba(0,0,0,.12); }
      nav { display: flex; align-items: center; justify-content: space-between; padding: 0.9rem 0; }
      .brand { display: flex; align-items: center; gap: 0.6rem; text-decoration: none; font-weight: 700; }
      .menu { display: flex; gap: 1.25rem; }
      .menu a { text-decoration: none; opacity: 0.85; }
      .menu a:hover { opacity: 1; text-decoration: underline; }
      main { padding: 2rem 0; }
      footer { border-top: 1px solid rgba(0,0,0,.12); margin-top: 3rem; padding: 1rem 0; opacity: 0.7; font-size: 0.95rem; }
    </style>
  </head>

  <body>
    <header>
      <div class="wrap">
        <nav>
          <a class="brand" href="/">
            <img src="/SimDeclogo.gif" alt="SimDec logo" style="height: 42px;" />
          </a>

          <div class="menu">
            <a href="/publications">Publications</a>
            <a href="/people">People</a>
            <a href="/posts">Posts</a> 
          </div>
        </nav>
      </div>
    </header>

    <div class="wrap">
      <main>
        <slot />
      </main>

      <footer>© {new Date().getFullYear()} SimDec</footer>
    </div>
  </body>
</html>