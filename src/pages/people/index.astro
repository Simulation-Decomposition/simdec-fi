---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const people = await getCollection("people");

const categoryOrder = ["contributors", "business-finland-2022", "sponsors"];

const categoryTitle = {
  contributors: "Contributors",
  "business-finland-2022": "Business Finland Project (2022)",
  sponsors: "Sponsors",
};

function sortByOrder(a, b) {
  return (a.data.order ?? 9999) - (b.data.order ?? 9999);
}
---

<Layout title="People | SimDec">
  <style>
    .peopleGrid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1.5rem;
      margin-top: 1rem;
    }
    @media (max-width: 1100px) {
      .peopleGrid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }
    @media (max-width: 820px) {
      .peopleGrid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
    @media (max-width: 520px) {
      .peopleGrid {
        grid-template-columns: 1fr;
      }
    }

    .personCard {
      border: 1px solid rgba(0,0,0,.12);
      border-radius: 14px;
      padding: 1rem;
      background: rgba(0,0,0,.01);
    }

    .avatar {
      width: 100%;
      aspect-ratio: 1 / 1;
      object-fit: cover;
      border-radius: 14px;
      border: 1px solid rgba(0,0,0,.12);
      display: block;
    }

    .personName {
      font-weight: 800;
      margin-top: 0.75rem;
      line-height: 1.25;
    }

    .personRole {
      opacity: 0.9;
      margin-top: 0.25rem;
      line-height: 1.35;
    }

    .personAffil {
      opacity: 0.75;
      margin-top: 0.15rem;
      font-size: 0.95rem;
      line-height: 1.35;
    }

    .linksRow {
      margin-top: 0.5rem;
    }
    .linksRow a {
      text-decoration: none;
      opacity: 0.9;
    }
    .linksRow a:hover {
      text-decoration: underline;
      opacity: 1;
    }

    .simpleList {
      list-style: none;
      padding: 0;
      margin: 1rem 0 0 0;
    }
    .simpleList li {
      margin: 1rem 0;
    }
  </style>

  <h1>People</h1>

  {categoryOrder.map((cat) => {
    const items = people.filter((p) => p.data.category === cat).sort(sortByOrder);
    if (items.length === 0) return null;

    // Contributors: grid cards
    if (cat === "contributors") {
      return (
        <section style="margin: 2.5rem 0;">
          <h2>{categoryTitle[cat]}</h2>

          <div class="peopleGrid">
            {items.map((p) => (
              <article class="personCard">
                {p.data.avatar ? (
                  <img class="avatar" src={p.data.avatar} alt={p.data.name} />
                ) : (
                  <div
                    style="width: 100%; aspect-ratio: 1 / 1; border-radius: 14px; border: 1px dashed rgba(0,0,0,.25); display: grid; place-items: center; opacity: 0.6;"
                  >
                    No photo
                  </div>
                )}

                <div class="personName">{p.data.name}</div>

                {p.data.role ? <div class="personRole">{p.data.role}</div> : null}
                {p.data.affiliation ? <div class="personAffil">{p.data.affiliation}</div> : null}

                {p.data.links?.length ? (
                  <div class="linksRow">
                    {p.data.links.map((l, i) => (
                      <>
                        <a href={l.url} target="_blank" rel="noopener noreferrer">
                          {l.label}
                        </a>
                        {i < p.data.links.length - 1 ? " · " : ""}
                      </>
                    ))}
                  </div>
                ) : null}
              </article>
            ))}
          </div>
        </section>
      );
    }

    // Other categories: simple list
    return (
      <section style="margin: 2.5rem 0;">
        <h2>{categoryTitle[cat]}</h2>

        <ul class="simpleList">
          {items.map((p) => (
            <li>
              <div style="font-weight: 800;">{p.data.name}</div>
              {p.data.role ? <div style="opacity: 0.9; margin-top: 0.2rem;">{p.data.role}</div> : null}
              {p.data.affiliation ? <div style="opacity: 0.75; margin-top: 0.15rem; font-size: 0.95rem;">{p.data.affiliation}</div> : null}

              {p.data.links?.length ? (
                <div style="margin-top: 0.35rem;">
                  {p.data.links.map((l, i) => (
                    <>
                      <a href={l.url} target="_blank" rel="noopener noreferrer">
                        {l.label}
                      </a>
                      {i < p.data.links.length - 1 ? " · " : ""}
                    </>
                  ))}
                </div>
              ) : null}
            </li>
          ))}
        </ul>
      </section>
    );
  })}
</Layout>