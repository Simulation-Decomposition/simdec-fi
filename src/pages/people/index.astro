---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const people = await getCollection("people");

// Order categories the way you want them to appear:
const categoryOrder = ["business-finland-2022", "sponsors", "contributors"];

const categoryTitle = {
  "business-finland-2022": "Business Finland project (2022)",
  sponsors: "Sponsors",
  contributors: "Contributors",
};
---

<Layout title="People | SimDec">
  <h1>People</h1>

  {categoryOrder.map((cat) => {
    const items = people
      .filter((p) => p.data.category === cat)
      .sort((a, b) => (a.data.order ?? 9999) - (b.data.order ?? 9999));

    if (items.length === 0) return null;

    return (
      <section style="margin: 2rem 0;">
        <h2>{categoryTitle[cat]}</h2>

        <ul style="padding-left: 1.2rem;">
          {items.map((p) => (
            <li style="margin: 0.9rem 0;">
              <div style="font-weight: 700;">{p.data.name}</div>

              {(p.data.role || p.data.affiliation) ? (
                <div style="opacity: 0.85;">
                  {p.data.role ? p.data.role : ""}
                  {p.data.role && p.data.affiliation ? " — " : ""}
                  {p.data.affiliation ? p.data.affiliation : ""}
                </div>
              ) : null}

              {p.data.links?.length ? (
                <div style="margin-top: 0.25rem;">
                  {p.data.links.map((l, i) => (
                    <>
                      <a href={l.url} target="_blank" rel="noopener noreferrer">
                        {l.label}
                      </a>
                      {i < p.data.links.length - 1 ? " · " : ""}
                    </>
                  ))}
                </div>
              ) : null}
            </li>
          ))}
        </ul>
      </section>
    );
  })}
</Layout>